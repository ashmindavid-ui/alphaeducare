# ── Resend (Email Notifications) ──────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address that receives booking & contact form submissions
NOTIFICATION_EMAIL=info@alphaglobaleducare.com

# Optional: Custom sender email (only use after verifying your domain
# in Resend at https://resend.com/domains)
# Default: Alpha Global Educare <onboarding@resend.dev>
# FROM_EMAIL=Alpha Global Educare <info@alphaglobaleducare.com>

# ── Vercel KV (Booking Slot Management) ──────────────────────────
# These are set automatically when you add Vercel KV to your project.
# See: https://vercel.com/docs/storage/vercel-kv
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
